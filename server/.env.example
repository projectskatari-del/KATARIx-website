# KATARIx Backend Environment Configuration Example
# Copy this file to a new file named '.env' and fill in your values.

# Port for the server to listen on (Render sets this automatically)
PORT=5000

# Your Neon PostgreSQL Connection String (Found in Neon Console under Connection Details)
DATABASE_URL=postgres://username:password@ep-host-name.neon.tech/dbname?sslmode=require

# Secure passcode for reading client submissions on admin.html
ADMIN_PASSCODE=KatariX_Secured_2026
